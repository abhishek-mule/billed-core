# Razorpay Configuration (Get from https://dashboard.razorpay.com)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXX

# n8n Webhooks Configuration
N8N_WEBHOOK_URL=http://n8n.localhost:5678/webhook

# Provisioning Sidecar (for Frappe invoice creation)
PROVISIONING_SIDECAR_URL=http://provisioning-sidecar:8001

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Frappe Configuration
FRAPPE_SITE_URL=http://frappe:8000
FRAPPE_API_KEY=your_api_key
FRAPPE_API_SECRET=your_api_secret

# Secret for JWT/Token generation
SECRET_KEY=your_secret_key_for_tokens
